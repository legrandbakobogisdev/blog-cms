{
    "framework": "nextjs",
    "functions": {
        "app/api/**": {
            "maxDuration": 30
        }
    },
    "headers": [
        {
            "source": "/api/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/:path*",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                }
            ]
        }
    ]
}